  {
    "id": "g5-direct-css-001",
    "description": "G5 direct: CSS color change matches CSS predicate (property in replace)",
    "edits": [
      {
        "file": "server.js",
        "search": "h1 { color: #1a1a2e; font-size: 2rem; }",
        "replace": "h1 { color: red; font-size: 2rem; }"
      }
    ],
    "predicates": [
      {
        "type": "css",
        "selector": "h1",
        "property": "color",
        "expected": "red",
        "path": "/"
      }
    ],
    "expectedSuccess": true,
    "tags": [
      "g5",
      "direct",
      "css",
      "property-match"
    ],
    "rationale": "Replace text contains \"color\" (property) — attributed as direct",
    "expectedAttributions": [
      "direct"
    ],
    "expectedSummary": {
      "direct": 1,
      "scaffolding": 0,
      "unexplained": 0
    },
    "intent": "false_negative"
  },
