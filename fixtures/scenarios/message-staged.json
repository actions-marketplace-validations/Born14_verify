  {
    "id": "msg-001",
    "description": "destination allowed: target in allow list",
    "envelope": {
      "destination": {
        "target": "#general",
        "platform": "slack"
      },
      "content": {
        "body": "Deploy complete for v2.0"
      },
      "sender": {
        "identity": "sovereign-agent"
      }
    },
    "policy": {
      "destinations": {
        "allow": [
          "#general",
          "#deploys"
        ]
      }
    },
    "expectedVerdict": "approved",
    "tags": [
      "message",
      "destination"
    ],
    "rationale": "#general is in the allow list"
  },
