{
  "name": "@sovereign-labs/verify",
  "version": "0.2.0",
  "description": "Verification gate for AI-generated code. Deterministic predicates, browser-level visual checks, constraint learning from failures. Every edit gets a fair trial before it touches your users.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "verify": "./src/cli.ts",
    "verify-mcp": "./src/mcp-server.ts"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "bun": "./src/types.ts",
      "import": "./src/types.ts"
    }
  },
  "scripts": {
    "test": "bun test tests/",
    "test:unit": "bun test tests/unit/",
    "test:integration": "bun test tests/integration/ --timeout 120000"
  },
  "files": [
    "src/",
    "README.md",
    "fixtures/",
    "scripts/harness/types.ts",
    "scripts/harness/runner.ts",
    "scripts/harness/oracle.ts",
    "scripts/harness/scenario-generator.ts",
    "scripts/harness/ledger.ts",
    "scripts/harness/report.ts"
  ],
  "license": "MIT",
  "keywords": [
    "ai-agents", "verification", "code-review", "ci-cd",
    "visual-testing", "browser-testing", "governance",
    "mcp", "agent-safety", "deploy-verification",
    "cursor", "copilot", "aider", "opendevin"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
